#!/usr/bin/env bash

# Debug mode
# set -x

# Tangkap Ctrl+C
trap 'echo -e "\nCancelled by user."; exit 0' SIGINT

# Cek yt-dlp
command -v yt-dlp >/dev/null 2>&1 || { echo "❌ yt-dlp not found! Please install first."; exit 1; }

url="$1"
perintah="${2:-ask}"

# === Fungsi === #
mp3() {
    outdir="$HOME/Music"
    mkdir -p "$outdir"
    echo "🎵 Downloading audio (mp3)..."
    yt-dlp -x --audio-format mp3 -o "$outdir/%(title)s.%(ext)s" "$url"
}
bestvideo() {
    outdir="$HOME/Videos"
    mkdir -p "$outdir"
    echo "🎬 Downloading video at best quality..."
    yt-dlp -f bestvideo+bestaudio/best --merge-output-format mp4 -o "$outdir/%(title)s.%(ext)s" "$url"
}
ask() {
    read -rp "Enter output folder (default: ~/Downloads): " outdir
    outdir="${outdir:-$HOME/Downloads}"
    mkdir -p "$outdir"

    echo "📡 Fetching available formats..."
    yt-dlp -F "$url"

    while true; do
        read -rp "Choose format (mp3/bestvideo/custom code): " pilihan
        if [[ -z "$pilihan" ]]; then
            echo "❌ Please make your choice!"
            continue
        fi

        case "$pilihan" in
            mp3) mp3 ;;
            bestvideo) bestvideo ;;
            *) yt-dlp -f "$pilihan+bestaudio/best" --merge-output-format mp4 \
                   -o "$outdir/%(title)s.%(ext)s" "$url" ;;
        esac
        break
    done
}

# Cek URL valid
if [[ ! "$url" =~ ^https?://(www\.)?(youtube\.com|youtu\.be)/ ]]; then
    echo "🚫 Only YouTube URLs are accepted!"
    exit 1
fi

# Trigger sesuai pilihan user
case "$perintah" in
    mp3) mp3 ;;
    bestvideo) bestvideo ;;
    ask|s) ask ;;
    *) echo "❌ Unrecognized option!"; exit 1 ;;
esac

# Notifikasi jika selesai mendownload
if command -v notify-send >/dev/null 2>&1; then
    notify-send -t 3000 "ytdownload" "Done! Saved to $outdir"
fi

echo "✅ Done! Saved to: $outdir"
